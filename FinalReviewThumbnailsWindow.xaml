<Window x:Class="ReviewTool.ReviewThumbnailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReviewTool"
        mc:Ignorable="d"
        Title="Review Thumbnails"
        Height="760"
        Width="1180"
        MinHeight="520"
        MinWidth="760"
        Background="#101318"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="ThumbSizeSliderStyle" TargetType="Slider">
            <Setter Property="Foreground" Value="#1E66E0"/>
            <Setter Property="Background" Value="#2F3136"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Margin="0,2,0,2">
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Focusable="False" Background="Transparent" BorderThickness="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="8"
                                                        Background="#2F3136"
                                                        CornerRadius="4" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Focusable="False" Background="Transparent" BorderThickness="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="8"
                                                        Background="#2F3136"
                                                        CornerRadius="4" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="16" Height="16" Background="#E5E7EA" BorderBrush="#1E66E0" BorderThickness="1">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RoundedMaxSizeTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1F27"/>
            <Setter Property="Foreground" Value="#F1F4F8"/>
            <Setter Property="BorderBrush" Value="#2A2F38"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ThumbnailFilterButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="Background" Value="#1A1F27"/>
            <Setter Property="Foreground" Value="#E5E7EA"/>
            <Setter Property="BorderBrush" Value="#2A2F38"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="#1E66E0"/>
                    <Setter Property="BorderBrush" Value="#3B82F6"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Margin="4,2,4,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Thumb size"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="#F1F4F8"/>
                <Slider x:Name="ThumbnailSizeSlider"
                        Style="{StaticResource ThumbSizeSliderStyle}"
                        Width="180"
                        Minimum="72"
                        Maximum="160"
                        Value="104"
                        TickFrequency="8"
                        IsSnapToTickEnabled="True"
                        ValueChanged="ThumbnailSizeSlider_ValueChanged"/>
                <TextBlock Text="Max"
                           VerticalAlignment="Center"
                           Margin="10,0,6,0"
                           Foreground="#F1F4F8"/>
                <TextBox x:Name="ThumbnailMaxSizeTextBox"
                         Style="{StaticResource RoundedMaxSizeTextBoxStyle}"
                         Width="46"
                         Text="160"
                         TextAlignment="Right"
                         LostFocus="ThumbnailMaxSizeTextBox_LostFocus"
                         KeyDown="ThumbnailMaxSizeTextBox_KeyDown"/>
            </StackPanel>
            <ItemsControl x:Name="FiltersItemsControl" Margin="0,8,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:ReviewThumbnailFilterItem}">
                        <Button Style="{StaticResource ThumbnailFilterButtonStyle}"
                                Content="{Binding ButtonLabel}"
                                Tag="{Binding ButtonTag}"
                                Click="FilterButton_Click" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
        <ListBox x:Name="ThumbnailsList"
                 Grid.Row="1"
                 Background="#101318"
                 BorderThickness="0"
                 Foreground="#F1F4F8"
                 VirtualizingPanel.IsVirtualizing="True"
                 ScrollViewer.CanContentScroll="False"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 SelectionChanged="ThumbnailsList_SelectionChanged">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="2,3,2,2"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#3E444D"/>
                            <Setter Property="BorderBrush" Value="#676F7D"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type local:ReviewThumbnailItem}">
                    <StackPanel Width="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ThumbnailItemWidth}">
                        <Border Background="#0E1218"
                                BorderBrush="#2A2F38"
                                BorderThickness="1"
                                Width="{Binding ThumbnailFrameWidth}"
                                Height="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ThumbnailTileHeight}"
                                HorizontalAlignment="Center">
                            <Border ClipToBounds="True">
                                <Image Source="{Binding Thumbnail}" Stretch="Uniform"/>
                            </Border>
                        </Border>
                        <TextBlock Text="{Binding Label}"
                                   FontSize="11"
                                   Margin="0,6,0,0"
                                   HorizontalAlignment="Center"
                                   Foreground="#F1F4F8"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
