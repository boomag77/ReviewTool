<Window x:Class="ReviewTool.FinalReviewThumbnailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReviewTool"
        mc:Ignorable="d"
        Title="Final Review Thumbnails"
        Height="760"
        Width="1180"
        MinHeight="520"
        MinWidth="760"
        Background="#101318"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="8">
        <ListBox x:Name="ThumbnailsList"
                 Background="#101318"
                 BorderThickness="0"
                 Foreground="#F1F4F8"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 SelectionChanged="ThumbnailsList_SelectionChanged">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="10,10,10,6"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#3E444D"/>
                            <Setter Property="BorderBrush" Value="#676F7D"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type local:FinalReviewThumbnailItem}">
                    <StackPanel Width="88">
                        <Border Background="#0E1218"
                                BorderBrush="#2A2F38"
                                BorderThickness="1"
                                Width="68"
                                Height="104"
                                HorizontalAlignment="Center">
                            <Border ClipToBounds="True">
                                <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"/>
                            </Border>
                        </Border>
                        <TextBlock Text="{Binding Label}"
                                   FontSize="15"
                                   Margin="0,6,0,0"
                                   HorizontalAlignment="Center"
                                   Foreground="#F1F4F8"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
